# ─────────────────────────────────────────────────────────
# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────
# Email (Resend) — used by Edge Functions server-side
# Set via: supabase secrets set RESEND_API_KEY=...
# ─────────────────────────────────────────────────────────
VITE_RESEND_API_KEY=

# ─────────────────────────────────────────────────────────
# App identity
# ─────────────────────────────────────────────────────────
VITE_APP_NAME=CRM
VITE_APP_URL=
