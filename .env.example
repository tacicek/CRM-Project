# ─────────────────────────────────────────────────────────
# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────
# Email (Resend) — used by Edge Functions server-side
# Set via: supabase secrets set RESEND_API_KEY=...
# ─────────────────────────────────────────────────────────
VITE_RESEND_API_KEY=

# ─────────────────────────────────────────────────────────
# App identity
# ─────────────────────────────────────────────────────────
VITE_APP_NAME=CRM
VITE_APP_URL=

# ─────────────────────────────────────────────────────────
# Edge Function secrets (set via: supabase secrets set KEY=value)
# These are NOT loaded client-side — server-side only
# ─────────────────────────────────────────────────────────
# APP_NAME=CRM
# SITE_URL=https://www.mycompany.com
# DASH_APP_URL=https://crm.mycompany.com
# SENDER_EMAIL=noreply@mycompany.com
# SENDER_NAME=CRM
# ADMIN_EMAIL=admin@mycompany.com
# CALENDAR_EMAIL=termine@mycompany.com
